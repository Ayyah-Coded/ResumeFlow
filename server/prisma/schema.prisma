generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Resume {
  id          String   @id @default(uuid())
  resumeId    String   @unique

  title       String
  clerkUserId String

  firstName   String?
  lastName    String?
  jobTitle    String?
  address     String?
  phone       String?
  email       String?

  summary     String?
  themeColor  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkUserId])

  experiences Experience[]
  education   Education[]
  skills      Skill[]
}

model Experience {
  id            String   @id @default(uuid())

  title         String
  companyName   String?
  city          String?
  state         String?
  startDate     String?
  endDate       String?
  workSummary   String?

  resumeId      String
  resume        Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([resumeId])
}

model Education {
  id             String   @id @default(uuid())

  universityName String
  degree         String?
  major          String?
  startDate      String?
  endDate        String?
  description    String?

  resumeId       String
  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([resumeId])
}

model AiUsage {
  id          String   @id @default(uuid())
  clerkUserId String
  usageDate   DateTime @db.Date
  count       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clerkUserId, usageDate])
}

model Skill {
  id       String   @id @default(uuid())

  name     String
  rating   Int

  resumeId String
  resume   Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeId])
}