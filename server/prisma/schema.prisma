generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Resume {
  id        String   @id @default(uuid())
  resumeId  String   @unique

  title     String
  userEmail String
  userName  String?

  firstName String?
  lastName  String?
  jobTitle  String?
  address   String?
  phone     String?
  email     String?

  summary   String?
  themeColor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  experiences Experience[]
  education   Education[]
  skills      Skill[]
}

model Experience {
  id            String   @id @default(uuid())

  title         String
  companyName   String?
  city          String?
  state         String?
  startDate     String?
  endDate       String?
  workSummary   String?

  resumeId      String
  resume        Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Education {
  id             String   @id @default(uuid())

  universityName String
  degree         String?
  major          String?
  startDate      String?
  endDate        String?
  description    String?

  resumeId       String
  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Skill {
  id       String   @id @default(uuid())

  name     String
  rating   Int

  resumeId String
  resume   Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}